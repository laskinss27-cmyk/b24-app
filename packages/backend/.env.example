# Локально скопировать в .env (он в .gitignore)

# Порт локального dev-сервера
PORT=3000

# Домен портала Б24 — куда ходят REST-вызовы и от кого ждём placement-запросы
PORTAL_DOMAIN=umniydom.bitrix24.ru

# Публичный URL нашего приложения — используется в placement.bind как handler.
# В проде задан в Y.Cloud Container env-переменной.
PUBLIC_BASE_URL=https://bba0fouaqgab742ohki8.containers.yandexcloud.net

# OAuth-приложение Б24 (получены при регистрации Локального приложения в Б24).
# В проде задаются в Y.Cloud env, в репо не коммитятся.
APP_CLIENT_ID=
APP_CLIENT_SECRET=

# Для проверки подписи placement-запросов (выдаётся при регистрации)
APP_SECRET=

# Вебхук «Автозадачи» — для тяжёлых операций без лимита 10 req/sec
# Используется только серверной стороной, во фронт не утекает
AUTOZADACHI_WEBHOOK=

# Локальный разведочный вебхук — для scripts/gen-types.ts и для локальных read-only проверок
DEV_WEBHOOK=

NODE_ENV=development
